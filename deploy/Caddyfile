# CUBIT — Caddy reverse proxy + automatic Let's Encrypt TLS (cubit.cash).
# Install: sudo cp deploy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy
#
# Caddy fronts the BACKEND/landing and the STATIC CLIENT only.
# The GAME SERVER (game.cubit.cash:8080) is NOT proxied here — it terminates its
# own TLS and speaks WebTransport/HTTP3 (QUIC/UDP), which a reverse proxy can't
# pass through. Point game.cubit.cash straight at the VPS (A record, DNS-only)
# and open TCP+UDP 8080.

# ── Backend + landing/login (Bun on :3001) ───────────────────────────────────
# Apex is the front door: landing page at /, API at /api/*, /play redirect.
cubit.cash, www.cubit.cash {
	encode zstd gzip
	header {
		# Trust/legitimacy signals (safe — don't affect framing or scripts)
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=31536000"
	}
	reverse_proxy 127.0.0.1:3001
}

# ── Static game client (hytopia-source build) ────────────────────────────────
play.cubit.cash {
	encode zstd gzip
	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Strict-Transport-Security "max-age=31536000"
	}
	root * /opt/cubit/client-dist
	try_files {path} /index.html
	file_server
}

# ── game.cubit.cash cert holder ──────────────────────────────────────────────
# The game server has its OWN TLS on :8080 (WebTransport). This block exists only
# so Caddy obtains & auto-renews the game.cubit.cash cert, which is then injected
# into the SDK by deploy/inject-game-cert.js (the SDK hardcodes its cert).
game.cubit.cash {
	redir https://play.cubit.cash{uri}
}

# Players land on https://cubit.cash → sign up / log in → /play redirects to
# https://play.cubit.cash/?join=game.cubit.cash:8080 (set as CUBIT_GAME_URL).
