# ── CUBIT production environment ─────────────────────────────────────────────
# Copy to `deploy/.env` on the server and fill in. Loaded by the systemd units
# (EnvironmentFile=) — see deploy/systemd/*.service. NEVER commit the real .env.

# Public domains (set up DNS A/AAAA records → your VPS IP first):
#   cubit.cash (+ www)  → auth backend / landing  (Caddy reverse-proxy → :3001)
#   play.cubit.cash     → static game client       (Caddy)
#   game.cubit.cash     → game server              (DIRECT to :8080, NOT proxied — see README)

# ── Auth backend (backend/server.ts) ─────────────────────────────────────────
# NOTE: do NOT set PORT here — both services load this file and the game server
# also reads PORT (it would collide on 3001). Ports are pinned per-unit instead
# (backend Environment=PORT=3001, game Environment=PORT=8080). Backend defaults
# to 3001 and the game to 8080 when PORT is unset.
# Strong random secret for HMAC-signed tokens. Generate: openssl rand -hex 32
CUBIT_SECRET=CHANGE_ME_openssl_rand_hex_32
# Where the backend's /play redirect sends players (the static client + join target):
CUBIT_GAME_URL=https://play.cubit.cash/?join=game.cubit.cash:8080

# ── Game server (index.ts) ───────────────────────────────────────────────────
# How the game server reaches the backend (server-to-server). Use the public api
# domain, or http://127.0.0.1:3001 if both run on the same host (faster, no TLS hop).
CUBIT_BACKEND_URL=http://127.0.0.1:3001

# ── Solana / reward economy (gold ↔ token bridge) ────────────────────────────
# Shared internal key so the game can ask the backend to send reward tokens.
CUBIT_INTERNAL_KEY=CHANGE_ME_openssl_rand_hex_24
# RPC + treasury (custodial). DEVNET for testing; see deploy/MAINNET.md to go live.
CUBIT_RPC=https://api.devnet.solana.com
CUBIT_TREASURY_SECRET=base58_treasury_secret_KEEP_PRIVATE
# The payout token. Devnet = self-minted test-USDC; mainnet = real USDC (6 decimals).
REWARD_MINT=63SyuXF3zGYV4wfz2DPy33Hsxf7jpwDjmqGDVDxFadTu
REWARD_DECIMALS=6
REWARD_SYMBOL=USDC
# Economy: gold per 1 token, min gold per withdraw, max tokens/account/24h.
# Peg: 10,000 gold = $1 (marketplace prices in index.ts assume this). min = $0.5, daily cap = $5.
REWARD_RATE=10000
REWARD_MIN_GOLD=5000
REWARD_DAILY_CAP=5
# Devnet faucet (landing "Get test USDC"). SET false ON MAINNET (real money).
FAUCET_ENABLED=true
FAUCET_AMOUNT=5
FAUCET_COOLDOWN_H=12
# $CUBIT (separate fixed-500K mainnet token, displayed on the landing):
# CUBIT_MINT=9oA6TFkdpaStyWJqUkX5dCMQAktSM16rjLtS7Vgaory

# ── toktx (KTX-Software) — required by the SDK at startup to build the atlas ──
# setup.sh installs it here and exports these; included for reference.
# PATH must contain the toktx binary; LD_LIBRARY_PATH its libs.
KTX_HOME=/opt/ktx
